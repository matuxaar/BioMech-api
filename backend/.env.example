SERVER_PORT=8080
DATABASE_URL=postgres://postgres:postgres@localhost:5432/desertacia?sslmode=disable
ML_SERVICE_URL=http://ml:8000
INTERNAL_API_KEY=change-me-in-production
FIREBASE_CREDENTIALS=/secrets/firebase-service-account.json
MIGRATIONS_DIR=migrations
UPLOADS_DIR=./uploads
AVATARS_DIR=./uploads/avatars
TRAINING_DIR=./uploads/training
DEV_MODE=true
CORS_ORIGINS=http://localhost:8080

# Server timeouts (Go duration format, e.g. "15s", "1m")
READ_TIMEOUT=15s
WRITE_TIMEOUT=30s
READ_HEADER_TIMEOUT=20s
IDLE_TIMEOUT=60s
ML_REQUEST_TIMEOUT=30s

# Upload limits
MAX_UPLOAD_SIZE_MB=50

# WebSocket
WS_BATCH_SIZE=32
WS_BUFFER_INIT_CAP=256
