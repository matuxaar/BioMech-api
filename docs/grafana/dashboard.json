{
  "title": "BioMech / Desertacia",
  "uid": "biomech",
  "version": 39,
  "tags": [],
  "panels": [
    {
      "title": "HTTP Requests / sec",
      "type": "graph",
      "targets": [
        { "expr": "rate(http_requests_total[1m])", "legendFormat": "{{method}} {{path}}" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 }
    },
    {
      "title": "Request Duration (p99)",
      "type": "heatmap",
      "targets": [
        { "expr": "histogram_quantile(0.99, rate(http_request_duration_seconds_bucket[5m]))", "legendFormat": "p99" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 }
    },
    {
      "title": "Active Requests",
      "type": "graph",
      "targets": [
        { "expr": "http_requests_active", "legendFormat": "active" }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 }
    },
    {
      "title": "Rate Limited Requests",
      "type": "graph",
      "targets": [
        { "expr": "rate(http_requests_rate_limited_total[1m])", "legendFormat": "rate limited" }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 }
    },
    {
      "title": "WebSocket Connections",
      "type": "graph",
      "targets": [
        { "expr": "websocket_connections_active", "legendFormat": "active WS" }
      ],
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 }
    },
    {
      "title": "WebSocket Messages / sec",
      "type": "graph",
      "targets": [
        { "expr": "rate(websocket_messages_total[1m])", "legendFormat": "{{direction}}" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 }
    },
    {
      "title": "Response Status Breakdown",
      "type": "piechart",
      "targets": [
        { "expr": "rate(http_requests_total[5m])", "legendFormat": "{{status}}" }
      ],
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 }
    }
  ],
  "schemaVersion": 39
}
